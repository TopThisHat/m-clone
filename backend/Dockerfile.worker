FROM python:3.12-slim
WORKDIR /app

# Copy the entire backend (app, worker, job_runner are all sibling packages)
COPY backend/ ./

RUN pip install uv && uv pip install --system \
    asyncpg openai pydantic-settings python-dotenv aiohttp \
    pydantic-ai anthropic tavily-python httpx Wikipedia-API yfinance rank-bm25 \
    python-jose authlib httpx itsdangerous

ENV PYTHONUNBUFFERED=1

CMD ["python", "-m", "worker.main"]
