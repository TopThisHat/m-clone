# ── AI providers ──────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
TAVILY_API_KEY=tvly-...
ANTHROPIC_API_KEY=          # optional — enables Claude Sonnet model option

# ── App ───────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=["http://localhost:5173"]
MAX_PDF_SIZE_MB=20
DEFAULT_MODEL=openai:gpt-4o

# ── Auth ──────────────────────────────────────────────────────────────────────
DEV_AUTH_BYPASS=true        # set false in production
JWT_SECRET=change-me-in-prod

# ── Local Docker services (docker compose up -d) ──────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/research
REDIS_URL=redis://localhost:6379

# ── OIDC (optional — leave blank for dev) ─────────────────────────────────────
OIDC_ISSUER=
OIDC_CLIENT_ID=m-clone
OIDC_CLIENT_SECRET=
APP_BASE_URL=http://localhost:5173
