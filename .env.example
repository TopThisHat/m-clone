# ── Backend ───────────────────────────────────────────────────────────────────
# Required: OpenAI API key for GPT-4o
OPENAI_API_KEY=sk-...

# Required: Tavily API key for web search (sign up free at https://app.tavily.com)
TAVILY_API_KEY=tvly-...

# Optional: Allowed CORS origins
ALLOWED_ORIGINS=["http://localhost:5173"]

# Optional: Maximum PDF upload size in MB
MAX_PDF_SIZE_MB=20

# ── Auth / Teams ───────────────────────────────────────────────────────────────
# JWT secret (change in production!)
JWT_SECRET=change-me-in-prod

# Dev auth bypass — allows POST /api/auth/dev-login without SSO (local dev only)
DEV_AUTH_BYPASS=true

# OIDC/SSO (production only — leave blank for dev bypass mode)
# OIDC_ISSUER=https://your-sso.company.com
# OIDC_CLIENT_ID=m-clone
# OIDC_CLIENT_SECRET=secret
# APP_BASE_URL=http://localhost:5173
